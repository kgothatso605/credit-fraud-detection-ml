# Copy this file to .env and fill in values after running deploy.py
# The dashboard reads these on startup.

# Azure ML Managed Online Endpoint scoring URI
# (printed at the end of: python deployment/azure/deploy.py)
AZURE_ENDPOINT_URL=https://<endpoint-name>.inference.ml.azure.com/score

# Primary API key for the endpoint
AZURE_ENDPOINT_KEY=<your-primary-key-here>
